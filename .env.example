# ── Perxona Connect (required) ───────────────────────────────────────────────
# Ask your Perxona contact for these. The server signs in with this one service
# account for every visitor — there is no per-user browser login.
PERXONA_API_BASE_URL=
PERXONA_CONNECT_EMAIL=
PERXONA_CONNECT_PASSWORD=

# Perxona presenter engine on the CDN. Leave blank to use the production default.
PRESENTER_URL=

# ── Default presentation target (optional) ───────────────────────────────────
# Pre-select the avatar / scene / voice so the demo needs no picker UI. Get the
# ids from GET /api/avatars, /api/scenes, /api/voices. If left blank, the
# frontend falls back to the first catalog item.
DEFAULT_AVATAR_ID=01KV7S3YHSN3VE4JPVW079N9TJ
DEFAULT_SCENE_ID=01KQBD9EBX9VQ32JB68WPVWVYK
DEFAULT_VOICE_ID=01KTBJ7FA5BP3FDHBJDASH4RHK

# ── Background broadcast video (required for the broadcast look) ──────────────
# A remote mp4 URL or an HLS .m3u8 stream. Played full-screen, muted, looping.
BROADCAST_VIDEO_URL=

# ── Speech-to-text (required to drive the avatar from your voice) ────────────
# Default adapter forwards mic audio to an OpenAI-compatible transcription API.
# STT_PROVIDER: "openai" (default) or "mock" (no key needed — types fake text).
STT_PROVIDER=openai
STT_API_KEY=
# Override for non-OpenAI compatible endpoints (e.g. Azure/Groq/local Whisper).
STT_BASE_URL=https://api.openai.com/v1
STT_MODEL=whisper-1
# BCP-47 language hint for the transcriber (e.g. zh, en, ja). Blank = auto.
STT_LANGUAGE=

# ── Server ───────────────────────────────────────────────────────────────────
# Port the Express backend serves on (default 8088).
PORT=8088
# Port the Vite dev server serves on in `npm run dev` (default 5173).
WEB_PORT=5173
